\pgfplotsset{
  area legend/.style = {
    legend image code/.code = {
      \fill[##1] (0cm,-0.1cm) rectangle (0.6cm,0.1cm);
    }
  },
  xbar legend/.style={
      legend image code/.code={
          \fill [##1,/tikz/.cd,bar width=3pt,yshift=-0.2em,bar shift=0pt]
          plot coordinates {(0cm,0.8em) (2*\pgfplotbarwidth,0.6em)};
      },
  },
  ybar legend/.style={
      legend image code/.code={
          \fill [##1,/tikz/.cd,bar width=3pt,yshift=-0.2em,bar shift=0pt]
          plot coordinates {(0cm,0.8em) (2*\pgfplotbarwidth,0.6em)};
      },
  },
  xbar interval legend/.style={
      legend image code/.code={
          \fill [##1,/tikz/.cd,yshift=-0.2em,bar interval width=0.7,bar interval shift=0.5]
          plot coordinates {(0cm,0.8em) (5pt,0.6em) (10pt,0.6em)};
      },
  },
  ybar interval legend/.style={
      legend image code/.code={
          \fill [##1,/tikz/.cd,yshift=-0.2em,bar interval width=0.7,bar interval shift=0.5]
          plot coordinates {(0cm,0.8em) (5pt,0.6em) (10pt,0.6em)};
      },
  },
  single xbar legend/.style={
      legend image code/.code={
          \fill[##1,/tikz/.cd,bar width=6pt,yshift=0.2ex,bar shift=0pt]
          plot coordinates {(0.8em,0pt)};
      },
  },
  single ybar legend/.style={
      legend image code/.code={
          \fill[##1,/tikz/.cd,bar width=6pt,yshift=-0.2em,bar shift=0pt]
          plot coordinates {(0pt,0.8em)};
      },
  },
}
  